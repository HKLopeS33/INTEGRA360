{
  "name": "@sistema/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:supabase": "prisma migrate dev --schema prisma/schema.supabase.prisma",
    "db:deploy:supabase": "prisma migrate deploy --schema prisma/schema.supabase.prisma",
    "db:seed": "node --env-file=.env prisma/seed.mjs",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0",
    "typescript": "^5.8.3"
  }
}
