generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPER
  GERENTE
  CAIXA
  GARCOM
  COZINHA
  ESTOQUE
  FINANCEIRO
}

enum TableStatus {
  LIVRE
  OCUPADA
  RESERVADA
  FECHANDO_CONTA
}

enum TabStatus {
  ABERTA
  FECHANDO
  FECHADA
  CANCELADA
}

enum OrderStatus {
  ENVIADO
  EM_PREPARO
  PRONTO
  ENTREGUE
  CANCELADO
}

enum PaymentMethod {
  DINHEIRO
  CREDITO
  DEBITO
  PIX
  VOUCHER
}

enum CashRegisterStatus {
  ABERTO
  FECHADO
}

enum SubscriptionStatus {
  ATIVO
  EXPIRADO
  SUSPENSO
  CANCELADO
}

enum PaymentStatus {
  PENDENTE
  PAGO
  INADIMPLENTE
}

model Company {
  id           String      @id @default(cuid())
  name         String
  cnpj         String      @unique
  email        String      @unique
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String?      @default("BR")
  pixKey       String?      
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  users        User[]       @relation("CompanyUsers")
  subscription Subscription?
  payments     PaymentRecord[]
  tables       RestaurantTable[]
  categories   Category[]
  products     Product[]
  tabs         Tab[]
  orders       Order[]
  cashRegisters CashRegister[]
  auditLogs    AuditLog[]
}

model Subscription {
  id           String      @id @default(cuid())
  companyId    String      @unique
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status       SubscriptionStatus @default(ATIVO)
  monthlyFee   Decimal     @default(0)
  expiresAt    DateTime
  lastRenewed  DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastLoginAt  DateTime?
}

model PaymentRecord {
  id           String      @id @default(cuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  amount       Decimal
  status       PaymentStatus @default(PENDENTE)
  dueDate      DateTime
  paidAt       DateTime?
  renewalDate  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model User {
  id                 String      @id @default(cuid())
  name               String
  email              String      @unique
  passwordHash       String
  role               UserRole
  active             Boolean     @default(true)
  mustChangePassword Boolean     @default(false)
  companyId          String?
  company            Company?    @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: SetNull)
  managerId          String?
  manager            User?       @relation("UserManager", fields: [managerId], references: [id])
  subordinates       User[]      @relation("UserManager")
  lastLoginAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  tabsOpened         Tab[]       @relation("TabOpenedBy")
  orders             Order[]
  cashOpened         CashRegister[] @relation("CashOpenedBy")
  cashClosed         CashRegister[] @relation("CashClosedBy")
  auditLogs          AuditLog[]  @relation("UserAudit")
}

model RestaurantTable {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  number    Int
  name      String
  capacity  Int
  status    TableStatus @default(LIVRE)
  active    Boolean     @default(true)
  tabs      Tab[]
  @@unique([companyId, number])
}

model Tab {
  id                  String          @id @default(cuid())
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tableId             String
  openedById          String
  status              TabStatus       @default(ABERTA)
  openedAt            DateTime        @default(now())
  closedAt            DateTime?
  receiptNumber       Int?
  receiptGeneratedAt  DateTime?
  subtotal            Decimal         @default(0)
  discount            Decimal         @default(0)
  serviceFee          Decimal         @default(0)
  total               Decimal         @default(0)
  table               RestaurantTable @relation(fields: [tableId], references: [id])
  openedBy            User            @relation("TabOpenedBy", fields: [openedById], references: [id])
  orders              Order[]
  payments            Payment[]
}

model Category {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  sort      Int       @default(0)
  active    Boolean   @default(true)
  products  Product[]
  @@unique([companyId, name])
}

model Product {
  id                 String      @id @default(cuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId         String
  name               String
  description        String?
  price              Decimal
  cost               Decimal     @default(0)
  internalCode       String?
  barcode            String?
  preparationMinutes Int         @default(0)
  available          Boolean     @default(true)
  active             Boolean     @default(true)
  category           Category    @relation(fields: [categoryId], references: [id])
  orderItems         OrderItem[]
  @@unique([companyId, internalCode])
}

model Order {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tabId     String
  userId    String
  status    OrderStatus @default(ENVIADO)
  origin    String      @default("mesa")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tab       Tab         @relation(fields: [tabId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id        String      @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal
  note      String?
  status    OrderStatus @default(ENVIADO)
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id])
  product   Product     @relation(fields: [productId], references: [id])
}

model CashRegister {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  openedById      String
  closedById      String?
  openedAt        DateTime           @default(now())
  closedAt        DateTime?
  initialAmount   Decimal            @default(0)
  closingAmount   Decimal?
  status          CashRegisterStatus @default(ABERTO)
  openedBy        User               @relation("CashOpenedBy", fields: [openedById], references: [id])
  closedBy        User?              @relation("CashClosedBy", fields: [closedById], references: [id])
  payments        Payment[]
}

model Payment {
  id             String         @id @default(cuid())
  tabId          String
  cashRegisterId String
  method         PaymentMethod
  amount         Decimal
  status         String         @default("confirmado")
  createdAt      DateTime       @default(now())
  tab            Tab            @relation(fields: [tabId], references: [id])
  cashRegister   CashRegister   @relation(fields: [cashRegisterId], references: [id])
}

model SyncEvent {
  id           String    @id @default(cuid())
  type         String
  payloadJson  String
  createdAt    DateTime  @default(now())
  syncedAt     DateTime?
  attempts     Int       @default(0)
  error        String?
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation("UserAudit", fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  dataJson  String?
  createdAt DateTime @default(now())
}
