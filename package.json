{
  "name": "sistema-shawarma",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema local com integracao web para gestao de restaurante.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @sistema/desktop",
    "dev:desktop": "npm run dev --workspace @sistema/desktop",
    "build": "npm run build --workspace @sistema/desktop && npm run build:desktop",
    "build:desktop": "npm run build:electron --workspace @sistema/desktop",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1"
  }
}
