{
  "name": "integra360",
  "version": "1.1.0",
  "private": true,
  "description": "Sistema de gestão para restaurantes Integra360.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @integra360/desktop",
    "dev:desktop": "npm run dev --workspace @integra360/desktop",
    "build": "npm run build --workspace @integra360/desktop && npm run build:desktop",
    "build:desktop": "npm run build:electron --workspace @integra360/desktop",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1"
  }
}
